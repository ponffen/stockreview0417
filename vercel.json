{
  "buildCommand": "npm run build",
  "functions": {
    "api/assets.js": {
      "includeFiles": "api/public/**"
    },
    "api/index.js": {
      "includeFiles": "api/public/**"
    },
    "api/static.js": {
      "includeFiles": "api/public/**"
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/health/db", "dest": "/api/health-db" },
    { "src": "/api/health", "dest": "/api/health" },
    { "src": "/api/health/", "dest": "/api/health" },
    { "src": "/api/assets/?", "dest": "/api/assets" },
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/favicon.ico", "dest": "/api/assets?file=favicon.ico" },
    { "src": "/styles.css", "dest": "/api/assets?file=styles.css" },
    { "src": "/app.js", "dest": "/api/assets?file=app.js" },
    { "src": "/site-state.json", "dest": "/api/assets?file=site-state.json" },
    { "src": "/(.*)", "dest": "/api" }
  ]
}
